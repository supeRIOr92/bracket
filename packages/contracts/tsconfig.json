{
"compilerOptions": {
"target": "ES2020",
"module": "CommonJS",
"moduleResolution": "node",
"esModuleInterop": true,
"forceConsistentCasingInFileNames": true,
"strict": true,
"skipLibCheck": true,
"resolveJsonModule": true,
"outDir": "dist"
},
"include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts"],
"exclude": ["node_modules"]
}
