{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "PRIVY_APP_ID",
    "PRIVY_APP_SECRET",
    "CHAINLINK_BTC_USD_BASE",
    "RPC_URL_BASE",
    "DEPLOYER_PRIVATE_KEY",
    "USDC_ADDRESS_BASE",
    "CONTRACT_ADDRESS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "compile": {
      "outputs": ["artifacts/**", "typechain-types/**"]
    },
    "deploy": {
      "dependsOn": ["compile"]
    },
    "migrate": {}
  }
}